//ESSE PROGAMA É UMA CALCULADORA SIMPLES COM OS PRINCIPAIS DOS CALCULOS

#include <stdio.h>
#include <locale.h>
#include <stdlib.h> 

void MENU() {
    printf("\n============================\n");
    printf("     CALCULADORA DEV   \n");
    printf("============================\n");
    printf("(1) SOMAR\n");
    printf("(2) SUBTRAIR\n");	
    printf("(3) MULTIPLICAR\n");
    printf("(4) DIVIDIR\n");
    printf("(0) SAIR\n");
    printf("\nESCOLHA UMA OPCAO: ");
}

int main() {
    setlocale(LC_ALL, "portuguese");
    
    int op;
    float n1, n2;

    do {
        MENU();
        scanf("%d", &op);

        if (op >= 1 && op <= 4) {
            printf("\nDIGITE O PRIMEIRO VALOR: ");
            scanf("%f", &n1);
            printf("DIGITE O SEGUNDO VALOR: ");
            scanf("%f", &n2);
        }

        switch(op) {
            case 1:
                printf("\n>>> RESULTADO DA SOMA: %.2f\n", n1 + n2);
                break;	
            case 2:
                printf("\n>>> RESULTADO DA SUBTRACAO: %.2f\n", n1 - n2);
                break;
            case 3:
                printf("\n>>> RESULTADO DA MULTIPLICACAO: %.2f\n", n1 * n2);
                break;				
            case 4:
                if (n2 != 0) {
                    printf("\n>>> RESULTADO DA DIVISAO: %.2f\n", n1 / n2);
                    
                    printf("NOTA: O resto inteiro da divisao e: %d\n", (int)n1 % (int)n2);
                } else {
                    printf("\nERRO: Nao e possivel dividir por zero!\n");
                }
                break;
            case 0:
                printf("\nSaindo... Obrigado por usar a Calculadora Dev!\n");
                break;
            default:
                printf("\nOPCAO INVALIDA! Tente novamente.\n");
        }
        
        printf("\nPressione ENTER para continuar...");
        getchar(); getchar(); 
        system("cls || clear"); 

    } while(op != 0);

    return 0;
}
